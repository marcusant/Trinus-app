# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Encriptação de dados de saúde (AES-256-GCM) — OBRIGATÓRIO (mín. 32 caracteres)
# Sem esta chave a app falha ao encriptar/decifrar (sem fallback inseguro).
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-min-32-chars-long-random-secret

# RapidAPI (ExerciseDB)
RAPIDAPI_KEY=your-rapidapi-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# App Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
